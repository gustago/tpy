{
  "name": "dictab",
  "displayName": "dictab",
  "description": "Edit .t.py Python files (record-oriented data) as Excel-like spreadsheets",
  "version": "0.0.1",
  "publisher": "dictab",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other",
    "Data Science"
  ],
  "main": "./dist/extension/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "dictab.spreadsheet",
        "displayName": "dictab Spreadsheet",
        "selector": [
          {
            "filenamePattern": "*.t.py"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "dictab.openSpreadsheet",
        "title": "Abrir como Planilha",
        "category": "dictab"
      },
      {
        "command": "dictab.openSource",
        "title": "Voltar para o código",
        "category": "dictab"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dictab.openSpreadsheet",
          "when": "resourceFilename =~ /\\.t\\.py$/",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "dictab",
      "properties": {
        "dictab.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Tema da planilha. 'auto' segue o tema do VSCode."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.webview.json && cp src/webview/styles.css dist/webview/",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "package": "npm run build && vsce package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vscode/vsce": "^2.24.0",
    "jsdom": "^29.1.0",
    "semantic-release": "^24.2.9",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
